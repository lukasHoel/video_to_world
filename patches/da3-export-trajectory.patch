+
+        # Export the corresponding camera trajectory as a NeRF-style transforms.json
+        # so that external viewers can reproduce the exact flythrough. We follow
+        # the common convention:
+        #   - global intrinsics in fl_x, fl_y, cx, cy, w, h
+        #   - per-frame "transform_matrix" as camera-to-world (c2w) 4x4 matrices.
+        extr_np = tgt_extr[idx].detach().cpu().numpy()  # (v, 4, 4), world2cam
+        intr_np = tgt_intr[idx].detach().cpu().numpy()  # (v, 3, 3), unnormalized
+
+        # Use the first frame's intrinsics as global intrinsics (typical practice).
+        fx = float(intr_np[0, 0, 0])
+        fy = float(intr_np[0, 1, 1])
+        cx = float(intr_np[0, 0, 2])
+        cy = float(intr_np[0, 1, 2])
+
+        transforms = {
+            "fl_x": fx,
+            "fl_y": fy,
+            "cx": cx,
+            "cy": cy,
+            "w": int(W),
+            "h": int(H),
+            "frames": [],
+        }
+        transforms["scale_factor"] = float(prediction.scale_factor) if prediction.is_metric else 1.0
+
+        num_frames = extr_np.shape[0]
+        # OpenCV (camera looks +Z, Y-down) -> NeRF/OpenGL (camera looks -Z, Y-up)
+        # conversion in the camera frame. For world-to-camera matrices, this is:
+        #   w2c_cv : world_cv -> cam_cv
+        #   F      : cam_cv  -> cam_gl  (diag(1, -1, -1, 1))
+        #   w2c_gl = F @ w2c_cv
+        # so c2w_gl = inv(w2c_gl) = inv(F @ w2c_cv) = c2w_cv @ F.
+        F = np.eye(4, dtype=np.float32)
+        F[1, 1] = -1.0
+        F[2, 2] = -1.0
+        for fi in range(num_frames):
+            # Convert world2cam (OpenCV) to cam2world in NeRF/OpenGL convention.
+            c2w_cv = np.linalg.inv(extr_np[fi])
+            c2w = c2w_cv @ F
+            transforms["frames"].append(
+                {
+                    # We don't have per-frame image files here; use a synthetic name.
+                    "file_path": f"{base_name}_frame_{fi:04d}.png",
+                    "transform_matrix": c2w.tolist(),
+                }
+            )
+
+        tf_path = os.path.join(export_dir, f"gs_video/{base_name}_transforms.json")
+        with open(tf_path, "w") as f:
+            json.dump(transforms, f, indent=2)
